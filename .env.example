# AI 合同审核系统 — 环境变量配置
# 复制为 .env 后修改，所有变量使用 CR_ 前缀
# 参考: src/contract_reviewer/models/config.py

# ──────────────────────────────────────
# LLM 配置
# ──────────────────────────────────────
CR_LLM_MODEL=anthropic/claude-sonnet-4-20250514
CR_LLM_API_BASE=
CR_LLM_API_KEY=
CR_LLM_TEMPERATURE=0.1
CR_LLM_MAX_OUTPUT_TOKENS=4096
CR_LLM_MAX_TOTAL_TOKENS=1000000
CR_LLM_MAX_CONCURRENT=5

# ──────────────────────────────────────
# 韧性 / 重试
# ──────────────────────────────────────
CR_LLM_MAX_RETRIES=3
CR_LLM_RETRY_BASE_DELAY=1.0
CR_LLM_CIRCUIT_BREAKER_THRESHOLD=5
CR_LLM_CIRCUIT_BREAKER_RECOVERY=30

# ──────────────────────────────────────
# Embedding
# ──────────────────────────────────────
CR_EMBEDDING_MODEL=ollama/bge-large-zh
CR_EMBEDDING_API_BASE=http://localhost:11434

# ──────────────────────────────────────
# RAG / 向量检索
# ──────────────────────────────────────
CR_VECTORSTORE_PATH=./data/chroma
CR_RETRIEVAL_TOP_K=5
CR_USE_RERANKER=false
CR_RERANKER_MODEL=
CR_RAG_MODE=runtime_embed
# 可选值: runtime_embed | precomputed | disabled
CR_PRECOMPUTED_QUERIES_PATH=data/precomputed_queries.json

# ──────────────────────────────────────
# 分块
# ──────────────────────────────────────
CR_CHUNK_SIZE_TOKENS=512
CR_CHUNK_OVERLAP_TOKENS=64

# ──────────────────────────────────────
# 缓存
# ──────────────────────────────────────
CR_CACHE_ENABLED=true
CR_CACHE_DIR=./data/cache

# ──────────────────────────────────────
# 审核
# ──────────────────────────────────────
CR_COMPLETENESS_MAX_CHARS=8000
# CR_REVIEW_DIMENSIONS=risk_analysis,compliance,completeness,term_fairness

# ──────────────────────────────────────
# OCR（边缘部署，可选）
# ──────────────────────────────────────
CR_OCR_ENABLED=false
CR_OCR_PROVIDER=paddleocr
# 可选值: paddleocr | glm_ocr
# CR_OCR_LANGUAGES=ch,en
CR_OCR_USE_GPU=false
CR_OCR_DPI=300
CR_OCR_RESULT_ENDPOINT=

# ──────────────────────────────────────
# API 安全
# ──────────────────────────────────────
CR_API_KEY=
# 设置后需要在请求中携带 X-API-Key header

# ──────────────────────────────────────
# 路径
# ──────────────────────────────────────
CR_PROMPTS_DIR=config/prompts
CR_RULES_PATH=config/rules/default_rules.yaml
